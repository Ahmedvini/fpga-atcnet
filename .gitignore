# =============================================================================
# .gitignore — FPGA DB-ATCNet repo
#
# We keep:  rtl/, sim/, build.sh, sim/run_vivado_tests.sh, scripts/*.py
#           (our own helpers: gen_stimulus, golden_model, h5_to_mem, q88_*),
#           CLAUDE.md / README.md / architecture diagrams.
#
# We drop:  the trained model weights (.h5), the cloned reference repos
#           under scripts/db_atcnet_ref{,2}/, the generated golden tensors
#           and weight exports under data/, and all Vivado/xsim/yosys
#           working files.
# =============================================================================

# ----- Trained model + Python golden artefacts (regeneratable) -----
*.h5
*.hdf5
*.keras
*.pt
*.pth
*.ckpt
*.tflite
*.onnx

# Generated golden tensors + Q-format references + weight .mem exports.
# Anything under data/ is reproducible from the .h5 via scripts/*.py.
/data/

# Trained model artefacts (per-subject .h5 + CV results + training plots).
# Reproducible from the AI team's training pipeline; not part of the RTL.
/weights/

# Cloned reference Python source (re-clone with `git clone` from upstream).
/scripts/db_atcnet_ref/
/scripts/db_atcnet_ref2/

# Claude Code per-user overrides (auto-approve config, etc.)
.claude/settings.local.json

# Python build artifacts
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.env

# ----- Vivado / xsim / xvlog / xelab work products -----
xsim.dir/
.Xil/
*.jou
*.log
*.pb
*.wdb
*.wcfg
*.str
*.backup.jou
*.backup.log
work.*
webtalk*.log
webtalk*.backup.log
xvlog.pb
xelab.pb
xsim.pb
hs_err_pid*.log

# Synthesis / impl outputs
/build/
/synth/build/
*.dcp
*.rpt
*.rpx
*.edif
*.edn
fsm_encoding_report*

# Vivado project files (if you create one)
*.cache/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
*.srcs/
*.gen/
*.xpr
*.bit
*.bin
*.ltx
*.hwh
*.bif
*.mmi

# Vitis / Vitis HLS / SDK workspace artifacts
.metadata/
.settings/
.cproject
.project
Debug/
Release/
*.elf
*.ihx
*.bin.S
RemoteSystemsTempFiles/

# Block design / IPI artefacts
*.bd.bak
*_wrapper.v
*_wrapper.vhd

# Yosys output
*.synlist
*.netlist.json

# ----- Waveform / capture files (regeneratable, often large) -----
*.vcd
*.fst
*.ghw
*.evcd
*.lxt
*.lxt2

# ----- Editor / OS noise -----
.DS_Store
Thumbs.db
*.swp
*.swo
*~
*.bak
*.tmp
tags
.tags
.idea/
.vscode/
.history/
*.code-workspace

# ----- ad-hoc scratch -----
/scratch/
/tmp/
/tmp_*/
TODO.local.md
NOTES.local.md
CODEX_HANDOFF.md
BRINGUP_CHECKLIST.md
PHASE_B_BRINGUP.md
thesis.md
thesis /archticture
thesis /block diagram
thesis /device
thesis /full curcuit
thesis /info of fpga.pdf
thesis /schematic
thesis /slice
thesis /utilization report
